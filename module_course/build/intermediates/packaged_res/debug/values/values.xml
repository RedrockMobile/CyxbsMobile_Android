    <declare-styleable name="ScheduleView" ns1:ignore="ResourceName">
        <!-- elementGap这个参数是用来调整item间距的,并且与GridView不同,这个在边界上也会添加-->
        <attr format="dimension" name="elementGap"/>
        <!-- 没有课的时候，显示的图片的宽高,若需要显示没课时的提示，必须加这两个属性-->
        <attr format="dimension" name="noGourseImageHeight"/>
        <attr format="dimension" name="noGourseImageWidth"/>
        <attr format="color" name="touchViewColor"/>
        <attr format="dimension" name="heightAtLowDpi"/>
        <attr format="reference" name="touchViewDrawable"/>
        <attr format="color" name="highlightColor"/>
        <attr format="reference" name="noCourseDrawable"/>
        <attr format="string" name="emptyText"/>
        <attr format="dimension" name="emptyTextSize"/>
        <attr format="boolean" name="isDisplayCourse"/>
        <attr format="reference" name="ScheduleViewStyle"/>
    </declare-styleable>
    <declare-styleable name="SimpleDotsView" ns1:ignore="ResourceName">
        <attr format="dimension" name="dotRadius"/>
        <attr format="dimension" name="dotGap"/>

        <attr format="reference" name="SimpleDotsViewStyle"/>
    </declare-styleable>
