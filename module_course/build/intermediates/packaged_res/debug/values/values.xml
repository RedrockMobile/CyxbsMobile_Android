    <declare-styleable name="RedRockTextView" ns1:ignore="ResourceName">
        <!--<attr name="strings" format="reference" />-->
        <attr format="reference" name="displayedStrings"/>
        <attr format="color" name="selectedColor"/>
        <attr format="enum" name="orientation">
            <enum name="vertical" value="1"/>
            <enum name="horizontal" value="0"/>
        </attr>
        <attr format="integer" name="offsetBetweenText"/>

        <attr format="reference" name="RedRockTextViewStyle"/>
    </declare-styleable>
    <declare-styleable name="RedRockTipsView" ns1:ignore="ResourceName">
